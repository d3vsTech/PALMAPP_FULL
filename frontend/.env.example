# ── PalmApp — Variables de entorno del frontend ──────────────────────────────
# Copiar este archivo a .env y completar los valores reales.
# NUNCA commitar el .env al repositorio (ya está en .gitignore)

# URL base de la API backend
# Desarrollo local: http://localhost:8000/api  o  http://agro-campo.test/api
# Producción: https://tu-dominio.com/api
VITE_API_URL=http://agro-campo.test/api

# URL del frontend (usada por el backend para generar enlaces de correo)
VITE_APP_URL=http://localhost:5173
